{
  "title": "PaymentFlow / JVM & Infrastructure",
  "uid": "paymentflow-jvm-infra",
  "editable": true,
  "timezone": "utc",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["paymentflow"],
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "JVM heap usage (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 * sum by (application) (jvm_memory_used_bytes{area=\"heap\"}) / sum by (application) (jvm_memory_max_bytes{area=\"heap\"})",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "GC pause time (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum by (application) (rate(jvm_gc_pause_seconds_sum[5m]))", "legendFormat": "{{application}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Live threads",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "jvm_threads_live_threads", "legendFormat": "{{application}}", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HikariCP connections (active / idle)",
      "description": "identity/merchant/payment/transaction/audit/notification/analytics-service — every Postgres-backed service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "hikaricp_connections_active", "legendFormat": "active {{application}}", "refId": "A" },
        { "expr": "hikaricp_connections_idle", "legendFormat": "idle {{application}}", "refId": "B" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Resilience4j: merchantService bulkhead usage",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "resilience4j_bulkhead_available_concurrent_calls{name=\"merchantService\"}", "legendFormat": "available slots", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Kafka consumer fetch lag (max), where applicable",
      "description": "transaction/audit/notification/analytics-service consumers of payment.events",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "kafka_consumer_fetch_manager_records_lag_max", "legendFormat": "{{application}} / {{client_id}}", "refId": "A" }
      ]
    }
  ],
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "query": "prometheus", "current": { "text": "Prometheus", "value": "Prometheus" } }
    ]
  }
}
