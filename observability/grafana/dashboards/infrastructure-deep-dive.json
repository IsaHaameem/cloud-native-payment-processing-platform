{
  "title": "PaymentFlow / Infrastructure Deep-Dive",
  "uid": "paymentflow-infra-deep-dive",
  "editable": true,
  "timezone": "utc",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["paymentflow", "m14"],
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Redis: ops/sec",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "redis_instantaneous_ops_per_sec", "legendFormat": "ops/sec", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Redis: memory used",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "redis_memory_used_bytes", "legendFormat": "used", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Redis: keyspace hit ratio (%)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "100 * rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m]))", "legendFormat": "hit ratio", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Redis: connected clients",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "redis_connected_clients", "legendFormat": "clients", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "PostgreSQL: transactions/sec (commit + rollback)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum by (datname) (rate(pg_stat_database_xact_commit[1m]) + rate(pg_stat_database_xact_rollback[1m]))", "legendFormat": "{{datname}}", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "PostgreSQL: buffer cache hit ratio (%)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "100 * sum(rate(pg_stat_database_blks_hit[5m])) / (sum(rate(pg_stat_database_blks_hit[5m])) + sum(rate(pg_stat_database_blks_read[5m])))", "legendFormat": "cache hit ratio", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "PostgreSQL: active connections",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum by (datname) (pg_stat_database_numbackends)", "legendFormat": "{{datname}}", "refId": "A" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Kafka: broker-side messages/sec by topic",
      "description": "kafka-exporter, real broker offset delta -- not client-reported throughput",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum by (topic) (rate(kafka_topic_partition_current_offset[1m]))", "legendFormat": "{{topic}}", "refId": "A" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Kafka: consumer group lag (broker-side)",
      "description": "kafka-exporter's own view of lag -- complements the client-side kafka_consumer_fetch_manager_records_lag_max panel on the JVM & Infrastructure dashboard",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "kafka_consumergroup_lag", "legendFormat": "{{consumergroup}} / {{topic}} / p{{partition}}", "refId": "A" }
      ]
    }
  ],
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "query": "prometheus", "current": { "text": "Prometheus", "value": "Prometheus" } }
    ]
  }
}
