# Copy to `.env` (which is git-ignored) and adjust as needed for local dev.
#   cp .env.example .env
#
# These values feed docker-compose.infra.yml. Real secrets NEVER live in git;
# on AWS these come from Secrets Manager (added in a later phase).

# NOTE: host-published ports use a dedicated paymentflow range (55xxx/56xxx/59xxx)
# so this stack coexists with other local databases/brokers. Containers still talk
# to each other on standard internal ports (postgres:5432, redis:6379, kafka:19092).

# ── PostgreSQL ──────────────────────────────────────────────────────────
POSTGRES_USER=paymentflow
POSTGRES_PASSWORD=paymentflow
POSTGRES_DB=paymentflow
POSTGRES_PORT=55432

# ── Redis ───────────────────────────────────────────────────────────────
REDIS_PASSWORD=paymentflow
REDIS_PORT=56379

# ── Kafka ───────────────────────────────────────────────────────────────
# This is BOTH the host-published port and the advertised host-listener port.
KAFKA_PORT=59092
KAFKA_UI_PORT=8085

# ── Observability (M13) ────────────────────────────────────────────────
# Standard ports for each tool, except Grafana and Prometheus: 3000 is
# deliberately avoided since it's already claimed by the eventual M15 Next.js
# frontend; 3001 and Prometheus's own default 9090 both turned out to already
# be taken too, by an unrelated project's own Grafana/Prometheus containers
# on this dev machine — exactly the kind of real, encountered-in-practice
# collision this project's dedicated-range convention (D9) exists to avoid.
# 3002/9091 confirmed free.
PROMETHEUS_PORT=9091
ALERTMANAGER_PORT=9093
LOKI_PORT=3100
TEMPO_PORT=3200
GRAFANA_PORT=3002
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=paymentflow
