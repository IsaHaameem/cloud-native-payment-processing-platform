# Copy to `.env` (which is git-ignored) and adjust as needed for local dev.
#   cp .env.example .env
#
# These values feed docker-compose.infra.yml. Real secrets NEVER live in git;
# on AWS these come from Secrets Manager (added in a later phase).

# NOTE: host-published ports use a dedicated paymentflow range (55xxx/56xxx/59xxx)
# so this stack coexists with other local databases/brokers. Containers still talk
# to each other on standard internal ports (postgres:5432, redis:6379, kafka:19092).

# ── PostgreSQL ──────────────────────────────────────────────────────────
POSTGRES_USER=paymentflow
POSTGRES_PASSWORD=paymentflow
POSTGRES_DB=paymentflow
POSTGRES_PORT=55432

# ── Redis ───────────────────────────────────────────────────────────────
REDIS_PASSWORD=paymentflow
REDIS_PORT=56379

# ── Kafka ───────────────────────────────────────────────────────────────
# This is BOTH the host-published port and the advertised host-listener port.
KAFKA_PORT=59092
KAFKA_UI_PORT=8085
