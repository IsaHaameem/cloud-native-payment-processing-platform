# ── Gradle ──────────────────────────────────────────────────────────────
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/**/build/
!**/gradle/wrapper/gradle-wrapper.jar

# ── Java / JVM ──────────────────────────────────────────────────────────
*.class
*.log
*.jar
!gradle-wrapper.jar
*.war
*.ear
hs_err_pid*
replay_pid*

# ── IDEs ────────────────────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.vscode/
.settings/
.project
.classpath
bin/
out/
.nb-gradle/

# ── OS ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Environment & secrets (NEVER commit real secrets) ───────────────────
.env
*.env
!.env.example
*.pem
*.key
# Anchored to the repo root only — an unanchored "secrets/" also matched
# terraform/modules/secrets/ (a legitimate Terraform module defining secret
# *infrastructure*, no real secret values) and silently kept it out of every
# commit since M11 without anyone noticing (found while trying to commit a
# real fix to that module and seeing git report no changes).
/secrets/

# ── Docker ──────────────────────────────────────────────────────────────
**/data/

# ── Node / frontend (added in later phases) ─────────────────────────────
node_modules/
.next/
npm-debug.log*
yarn-error.log*

# ── Terraform (added in Phase 4) ────────────────────────────────────────
*.tfstate
*.tfstate.*
.terraform/
*.tfvars
!*.tfvars.example
*.tfplan
override.tf
