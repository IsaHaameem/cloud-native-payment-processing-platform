# Normalize line endings across OSes so builds/CI are deterministic.
* text=auto eol=lf

# Windows-only files must keep CRLF.
*.bat        text eol=crlf
*.cmd        text eol=crlf

# The Gradle wrapper script must stay LF (executed by sh on Linux/CI).
gradlew      text eol=lf

# Binary files — never normalize.
*.jar        binary
*.png        binary
*.jpg        binary
*.gif        binary
*.ico        binary
*.keystore   binary
gradle/wrapper/gradle-wrapper.jar binary
